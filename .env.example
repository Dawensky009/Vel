# --- Mode maintenance -------------------------------------------------------
# Quand MAINTENANCE_MODE vaut "on", tout le site affiche la page « en
# préparation » SAUF le propriétaire. Toute autre valeur (ou variable absente)
# = site public normal. Se règle dans Vercel puis redéploiement (aucun code).
MAINTENANCE_MODE=on

# Jeton secret d'aperçu. Le propriétaire ouvre une fois :
#   https://vacancesenlivres.org/?apercu=VOTRE_JETON
# → un cookie retient l'appareil et laisse voir le vrai site partout.
# Mettre une longue chaîne aléatoire (ex. `openssl rand -hex 24`). Ne pas commiter.
MAINTENANCE_BYPASS_TOKEN=remplacez-par-une-longue-chaine-aleatoire
